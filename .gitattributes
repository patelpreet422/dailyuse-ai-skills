# Keep line endings stable and skills portable across machines.
# Default: normalize to LF in the repo so shell scripts inside skills stay runnable.
* text=auto eol=lf

# Windows-only scripts keep CRLF in the working tree.
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
